{
  "name": "concord",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter concord-sync-server --filter concord-text run dev",
    "build": "pnpm --filter concord-core run build && pnpm --filter concord-sync-server run build && pnpm --filter concord-text run build",
    "test": "pnpm --filter concord-core run test:run",
    "start": "pnpm --filter concord-sync-server run start"
  }
}

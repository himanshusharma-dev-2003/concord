# Production environment variables for concord-sync-server
# These are the ONLY vars needed in production — no development fallbacks here.
#
# Generate JWT_SECRET with: openssl rand -hex 32
#
# On Render: set these in the Environment tab of your web service,
#            or use render.yaml to declare them declaratively.

NODE_ENV=production

# Required: PostgreSQL connection string from your database provider
DATABASE_URL=postgres://user:password@host:5432/concord

# Required: cryptographically random secret — NEVER use the dev default
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Required: your deployed frontend URL (no trailing slash)
CORS_ORIGIN=https://concord-text.onrender.com

# Optional: defaults to 3001 — your platform may override this automatically
PORT=3001

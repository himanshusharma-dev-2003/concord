# Database — PostgreSQL, MongoDB, or omit to use local SQLite fallback
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.aixlreh.mongodb.net/?appName=Cluster0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crdt_editor

# Server
PORT=3001
NODE_ENV=development

# Auth — REQUIRED in production. Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# CORS — set to your frontend URL in production (e.g. https://concord.example.com)
# Leave unset to allow all origins (development only)
# CORS_ORIGIN=https://concord.example.com